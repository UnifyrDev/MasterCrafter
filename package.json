{
  "name": "unifyr-mastercrafter",
  "version": "1.0.1a",
  "private": true,
  "type": "module",
  "description": "MasterCrafter, the Unifyr D&D campaign preparation desktop app.",
  "homepage": "https://github.com/UnifyrDev/MasterCrafter",
  "author": {
    "name": "Vyxian",
    "email": "bombavyxianwitch@gmail.com"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist:win": "electron-vite build && electron-builder --win nsis",
    "dist:linux": "electron-vite build && electron-builder --linux deb rpm",
    "dist:linux:deb": "electron-vite build && electron-builder --linux deb",
    "dist:linux:rpm": "electron-vite build && electron-builder --linux rpm",
    "dist": "electron-vite build && electron-builder",
    "typecheck": "vue-tsc --noEmit -p tsconfig.renderer.json && tsc -p tsconfig.node.json --noEmit",
    "postinstall": "node ./scripts/postinstall.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "image-size": "^2.0.2",
    "jszip": "^3.10.1",
    "marked": "^16.1.2",
    "sanitize-html": "^2.17.0",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "@types/sanitize-html": "^2.16.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "electron": "^38.0.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "playwright": "^1.60.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vue-tsc": "^3.0.5"
  },
  "build": {
    "appId": "com.unifyr.mastercrafter",
    "productName": "MasterCrafter",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "maintainer": "Vyxian <bombavyxianwitch@gmail.com>",
      "target": [
        "deb",
        "rpm"
      ]
    }
  }
}
